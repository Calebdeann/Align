{
  "expo": {
    "name": "It Girl",
    "slug": "it-girl",
    "version": "1.0.0",
    "scheme": "itgirl",
    "orientation": "portrait",
    "icon": "./assets/Star Logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Star Splash Screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.itgirlapp.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {}
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Star Logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.itgirlapp.app",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-web-browser",
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      "expo-live-activity",
      "./plugins/withWorkoutWidget.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.2"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow It Girl to access your photos to add images to your workout templates.",
          "cameraPermission": "Allow It Girl to take photos for your workout templates."
        }
      ],
      [
        "react-native-share",
        {
          "ios": ["instagram-stories", "instagram", "twitter"]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "LiveActivity",
                  "bundleIdentifier": "com.itgirlapp.app.LiveActivity",
                  "entitlements": {
                    "com.apple.security.application-groups": ["group.com.aligntracker.app"]
                  }
                },
                {
                  "targetName": "ShareExtension",
                  "bundleIdentifier": "com.aligntracker.app.ShareExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": ["group.com.aligntracker.app"]
                  }
                }
              ]
            }
          }
        },
        "projectId": "27dc476a-dfdb-48f1-936b-7ec5fc70c4ae"
      }
    },
    "owner": "caleb.dean"
  }
}
